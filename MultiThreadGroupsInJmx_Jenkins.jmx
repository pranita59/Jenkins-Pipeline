      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="FishFlow">
        <stringProp name="TestPlan.comments">${__groovy(def tg=&quot;FishFlow&quot;; def groups=props.get(&quot;threadGroups&quot;); def config=props.get(&quot;threadConfig&quot;); if(groups!=null &amp;&amp; groups.contains(tg)){ def arr=config.split(&quot;,&quot;); for(item in arr){ if(item.startsWith(tg+&quot;:&quot;)){ return item.split(&quot;:&quot;)[1]; } } return &quot;1&quot;; } return &quot;0&quot;; )}
